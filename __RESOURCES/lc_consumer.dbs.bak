<?xml version="1.0" encoding="UTF-8" ?>
<project name="MariaDb" database="MariaDb" id="b802615b-2010-49eb-8326-217536925011" >
	<schema name="lc_consumer" >
		<table name="business_action" prior="business_ac" >
			<comment><![CDATA[Idempotent record of business side-effects executed by a consumer for a workflow instance.]]></comment>
			<column name="id" type="BIGINT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="instance_id" type="BIGINT" mandatory="y" />
			<column name="action_code" type="INT" mandatory="y" >
				<comment><![CDATA[Business action code (example: 100=SendLoginCredentials, 200=SendWarningEmail).]]></comment>
			</column>
			<column name="status" type="INT" mandatory="y" >
				<comment><![CDATA[Action execution state: 1=Pending, 2=Running, 3=Completed, 4=Failed.]]></comment>
			</column>
			<column name="started_at" prior="created" type="DATETIME" mandatory="y" >
				<comment><![CDATA[Execution start timestamp.]]></comment>
			</column>
			<column name="completed_at" type="DATETIME" length="6" >
				<comment><![CDATA[Execution completion timestamp.]]></comment>
			</column>
			<column name="result_json" type="LONGTEXT" >
				<comment><![CDATA[Structured execution result payload (JSON).]]></comment>
			</column>
			<column name="last_error" type="TEXT" />
			<index name="pk_business_action" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_business_action" unique="UNIQUE_KEY" >
				<column name="instance_id" />
				<column name="action_code" />
			</index>
			<fk name="fk_business_action_instance" to_schema="lc_consumer" to_table="instance" delete_action="cascade" >
				<fk_column name="instance_id" pk="id" />
			</fk>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="inbox" prior="workflow" row_count="0" spec="" >
			<comment><![CDATA[Canonical consumer-side record for one engine-raised transition or hook workload.]]></comment>
			<column name="id" type="BIGINT" length="20" mandatory="y" unsigned="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="ack_guid" type="VARCHAR" length="64" mandatory="y" >
				<comment><![CDATA[External acknowledgement GUID used for idempotency and correlation.]]></comment>
			</column>
			<column name="kind" type="TINYINT" length="3" mandatory="y" unsigned="y" >
				<comment><![CDATA[Workload kind: 1=Transition, 2=Hook.]]></comment>
			</column>
			<column name="handler_version" type="INT" >
				<comment><![CDATA[Pinned consumer handler version used for this workload.]]></comment>
			</column>
			<column name="on_success" type="INT" >
				<comment><![CDATA[Optional consumer action code to execute after successful processing.]]></comment>
			</column>
			<column name="on_failure" type="INT" >
				<comment><![CDATA[Optional consumer action code to execute after failed processing.]]></comment>
			</column>
			<column name="occurred" type="DATETIME" mandatory="y" >
				<comment><![CDATA[Domain occurrence timestamp from source event.]]></comment>
			</column>
			<column name="event_code" type="INT" >
				<comment><![CDATA[Transition event code; NULL when workload kind is Hook.]]></comment>
			</column>
			<column name="route" type="VARCHAR" length="200" >
				<comment><![CDATA[Hook route name; NULL when workload kind is Transition.]]></comment>
			</column>
			<column name="created" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was created.]]></comment>
			</column>
			<column name="handler_upgrade" type="TINYINT" mandatory="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[Handler strategy: 1=PinnedVersion, 2=AllowUpgradeToLatest.]]></comment>
			</column>
			<column name="run_count" type="INT" mandatory="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[Number of times this workload has been executed/retried.]]></comment>
			</column>
			<column name="instance_id" prior="entity_id" type="BIGINT" mandatory="y" />
			<index name="pk_inbox" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="idx_inbox_instance" unique="NORMAL" >
				<column name="instance_id" />
			</index>
			<index name="unq_inbox_ack_guid" unique="UNIQUE_KEY" >
				<column name="ack_guid" />
			</index>
			<index name="idx_inbox" unique="NORMAL" >
				<column name="route" />
			</index>
			<index name="idx_inbox_0" unique="NORMAL" >
				<column name="kind" />
			</index>
			<fk name="fk_inbox_instance" to_schema="lc_consumer" to_table="instance" delete_action="cascade" >
				<fk_column name="instance_id" pk="id" />
			</fk>
			<options><![CDATA[ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci]]></options>
		</table>
		<table name="inbox_action" prior="inbox_step" row_count="0" spec="" >
			<comment><![CDATA[Step-level execution tracking for inbox items to support deterministic, idempotent processing.]]></comment>
			<column name="inbox_id" prior="inbox_workflow_id" type="BIGINT" length="20" mandatory="y" unsigned="y" >
				<comment><![CDATA[Inbox record identifier (FK to inbox.id).]]></comment>
			</column>
			<column name="action_id" prior="action" type="BIGINT" mandatory="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Consumer business action]]></comment>
			</column>
			<column name="last_error" type="TEXT" >
				<comment><![CDATA[Last captured error message for troubleshooting.]]></comment>
			</column>
			<column name="status" type="TINYINT" mandatory="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[1 - Attempted, 2 - Completed, 3 - Failed]]></comment>
			</column>
			<index name="pk_inbox_action" unique="PRIMARY_KEY" >
				<column name="inbox_id" />
				<column name="action_id" />
			</index>
			<index name="fk_inbox_action_business_action" unique="NORMAL" >
				<column name="action_id" />
			</index>
			<fk name="fk_inbox_step_inbox" to_schema="lc_consumer" to_table="inbox" delete_action="cascade" >
				<fk_column name="inbox_id" pk="id" />
			</fk>
			<fk name="fk_inbox_action_business_action" to_schema="lc_consumer" to_table="business_action" delete_action="cascade" >
				<fk_column name="action_id" pk="id" />
			</fk>
			<options><![CDATA[ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci]]></options>
		</table>
		<table name="inbox_status" prior="inbox" row_count="0" spec="" >
			<comment><![CDATA[Durable processing state for engine-raised inbox deliveries received by a consumer.]]></comment>
			<column name="inbox_id" prior="wf_id" type="BIGINT" length="20" mandatory="y" unsigned="y" >
				<comment><![CDATA[Inbox record identifier (FK to inbox.id).]]></comment>
			</column>
			<column name="params_json" type="LONGTEXT" >
				<comment><![CDATA[Incoming parameter payload captured from engine (JSON).]]></comment>
			</column>
			<column name="received_at" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the item was received by the consumer.]]></comment>
			</column>
			<column name="modified" prior="processed_at" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was last updated.]]></comment>
			</column>
			<column name="status" prior="process_status" type="TINYINT" length="3" mandatory="y" unsigned="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[Inbox processing state: 1=Received, 2=Processing, 3=Processed, 4=Failed.]]></comment>
			</column>
			<column name="attempt_count" type="INT" length="10" mandatory="y" unsigned="y" >
				<defo><![CDATA[0]]></defo>
				<comment><![CDATA[Number of processing attempts performed for this record.]]></comment>
			</column>
			<column name="last_error" type="TEXT" >
				<comment><![CDATA[Last captured error message for troubleshooting.]]></comment>
			</column>
			<index name="pk_inbox_status" unique="PRIMARY_KEY" >
				<column name="inbox_id" />
			</index>
			<index name="idx_inbox_status" unique="NORMAL" >
				<column name="status" />
				<column name="received_at" />
			</index>
			<fk name="fk_inbox_status_inbox" to_schema="lc_consumer" to_table="inbox" delete_action="cascade" options="" >
				<fk_column name="inbox_id" pk="id" />
			</fk>
			<options><![CDATA[ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci]]></options>
		</table>
		<table name="instance" prior="workflow" >
			<comment><![CDATA[Consumer-side mirror of engine workflow instances. One row per engine instance guid.]]></comment>
			<column name="guid" prior="instance_guid" type="VARCHAR" length="42" mandatory="y" >
				<comment><![CDATA[instance guid (not generated here.. coming from the engine).. stored here as a duplicate only for proper sql queries and also for generating reports and easy tracking.]]></comment>
			</column>
			<column name="id" type="BIGINT" mandatory="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
			</column>
			<column name="def_name" type="VARCHAR" length="120" mandatory="y" />
			<column name="def_version" type="SMALLINT" mandatory="y" >
				<defo><![CDATA[1]]></defo>
			</column>
			<column name="entity_guid" type="VARCHAR" length="42" mandatory="y" />
			<column name="created" type="DATETIME" mandatory="y" >
				<comment><![CDATA[When this instance was created at the engine side, mirrored into the consumer database.]]></comment>
			</column>
			<index name="pk_instance" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="unq_instance_guid" unique="UNIQUE_KEY" >
				<column name="guid" />
			</index>
			<index name="idx_instance" unique="NORMAL" >
				<column name="def_name" />
				<column name="entity_guid" />
			</index>
			<index name="idx_instance_0" unique="NORMAL" >
				<column name="entity_guid" />
				<column name="def_name" />
			</index>
			<options><![CDATA[engine=InnoDB]]></options>
		</table>
		<table name="outbox" row_count="0" spec="" >
			<comment><![CDATA[Outbound acknowledgement queue from consumer to engine with retry scheduling.]]></comment>
			<column name="inbox_id" prior="wf_id" type="BIGINT" length="20" mandatory="y" unsigned="y" >
				<comment><![CDATA[Inbox record identifier (FK to inbox.id).]]></comment>
			</column>
			<column name="current_outcome" type="TINYINT" length="3" unsigned="y" >
				<comment><![CDATA[Current outcome: 1=Delivered, 2=Processed, 3=Retry, 4=Failed.]]></comment>
			</column>
			<column name="status" prior="send_status" type="TINYINT" length="3" mandatory="y" unsigned="y" >
				<defo><![CDATA[1]]></defo>
				<comment><![CDATA[Outbox send state: 1=Pending, 2=Sent, 3=Confirmed, 4=Failed.]]></comment>
			</column>
			<column name="next_retry_at" type="DATETIME" length="6" >
				<comment><![CDATA[Scheduled timestamp for next retry attempt.]]></comment>
			</column>
			<column name="last_error" type="TEXT" >
				<comment><![CDATA[Last captured error message for troubleshooting.]]></comment>
			</column>
			<column name="modified" prior="modified_at" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<column_options><![CDATA[ON UPDATE current_timestamp()]]></column_options>
				<comment><![CDATA[UTC timestamp when the row was last updated.]]></comment>
			</column>
			<column name="next_event" type="INT" />
			<index name="pk_outbox" unique="PRIMARY_KEY" >
				<column name="inbox_id" />
			</index>
			<index name="idx_outbox_send_status" unique="NORMAL" >
				<column name="status" />
				<column name="next_retry_at" />
			</index>
			<fk name="fk_outbox_inbox" to_schema="lc_consumer" to_table="inbox" delete_action="cascade" options="" >
				<fk_column name="inbox_id" pk="id" />
			</fk>
			<options><![CDATA[ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci]]></options>
		</table>
		<table name="outbox_history" row_count="0" spec="" >
			<comment><![CDATA[Immutable attempt history for outbox sends, responses, and failures.]]></comment>
			<column name="id" type="BIGINT" length="20" mandatory="y" unsigned="y" >
				<identity><![CDATA[AUTO_INCREMENT]]></identity>
				<comment><![CDATA[Internal surrogate identifier.]]></comment>
			</column>
			<column name="inbox_id" prior="outbox_id" type="BIGINT" length="20" mandatory="y" unsigned="y" >
				<comment><![CDATA[Inbox record identifier (FK to outbox.inbox_id).]]></comment>
			</column>
			<column name="outcome" type="TINYINT" length="3" mandatory="y" unsigned="y" >
				<comment><![CDATA[Attempt outcome: 1=Delivered, 2=Processed, 3=Retry, 4=Failed.]]></comment>
			</column>
			<column name="status" prior="send_status" type="TINYINT" length="3" mandatory="y" unsigned="y" >
				<comment><![CDATA[Attempt send state: 1=Pending, 2=Sent, 3=Confirmed, 4=Failed.]]></comment>
			</column>
			<column name="attempt_no" prior="attempt_count" type="INT" length="10" mandatory="y" unsigned="y" >
				<comment><![CDATA[Monotonic attempt sequence number.]]></comment>
			</column>
			<column name="modified" prior="sent_at" type="DATETIME" mandatory="y" >
				<defo><![CDATA[current_timestamp()]]></defo>
				<comment><![CDATA[UTC timestamp when the row was last updated.]]></comment>
			</column>
			<column name="response" prior="response_payload_json" type="LONGTEXT" >
				<comment><![CDATA[Raw response payload captured from engine/API (JSON). response payload _json]]></comment>
			</column>
			<column name="error" type="TEXT" >
				<comment><![CDATA[Error details captured for this send attempt.]]></comment>
			</column>
			<index name="pk_outbox_history" unique="PRIMARY_KEY" >
				<column name="id" />
			</index>
			<index name="idx_outbox_history_outbox_sent" unique="NORMAL" >
				<column name="inbox_id" />
				<column name="modified" />
			</index>
			<index name="unq_outbox_attempt" unique="UNIQUE_KEY" >
				<column name="inbox_id" />
				<column name="attempt_no" />
			</index>
			<fk name="fk_outbox_history_inbox" to_schema="lc_consumer" to_table="inbox" delete_action="cascade" >
				<fk_column name="inbox_id" pk="id" />
			</fk>
			<options><![CDATA[ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci]]></options>
		</table>
	</schema>
	<diagram_group name="Default" id="6df0d6c8-3421-41bf-ac60-5622f4579343" >
		<diagram name="Main Diagram" id="9443b33f-5de4-42b2-a6d5-e59d764d8dba" joined_routing="y" show_relation="no_text" >
			<entity schema="lc_consumer" name="business_action" color="C1D8EE" x="570" y="418" />
			<entity schema="lc_consumer" name="inbox" color="BED3F4" x="304" y="76" />
			<entity schema="lc_consumer" name="inbox_action" color="BED3F4" x="589" y="266" />
			<entity schema="lc_consumer" name="inbox_status" color="BED3F4" x="570" y="57" />
			<entity schema="lc_consumer" name="instance" color="C1D8EE" x="323" y="437" />
			<entity schema="lc_consumer" name="outbox" color="BED3F4" x="57" y="76" />
			<entity schema="lc_consumer" name="outbox_history" color="BED3F4" x="95" y="285" />
		</diagram>
	</diagram_group>
</project>